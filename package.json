{
  "name": "claude-workbench",
  "version": "1.0.0",
  "description": "Claude Code 기반 개발 워크스테이션",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ts && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "puppeteer": "^24.38.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.claudeworkbench.app",
    "productName": "Claude Workbench",
    "files": [
      "dist/**/*.js",
      "dist/**/*.js.map",
      "src/renderer/**/*",
      "assets/**/*",
      "package.json",
      "!__tests__",
      "!__mocks__",
      "!src/main/**",
      "!src/preload/**",
      "!src/shared/**",
      "!**/*.ts",
      "!**/*.d.ts",
      "!**/*.d.ts.map"
    ],
    "icon": "assets/icon.png",
    "directories": {
      "output": "build"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
